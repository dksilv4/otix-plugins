{
  "name": "Epic Games",
  "version": "0.1.0",
  "description": "Scan and match your Epic Games library with Otix media items. Login via OAuth, scan your library, and automatically match against the Otix database.",
  "author": "Diogo da Silva",
  "repository": "https://github.com/dksilv4/otix-plugins",
  "min_app_version": "0.3.0",
  "permissions": [
    "network:external",
    "storage:local",
    "events:subscribe",
    "notifications",
    "ui:settings",
    "api:proxy"
  ],
  "config": {
    "auto_sync": {
      "type": "boolean",
      "label": "Auto-scan on login",
      "default": true
    },
    "mark_as_owned": {
      "type": "boolean",
      "label": "Mark matched games as owned",
      "description": "Automatically add matched Epic games to your owned library",
      "default": true
    },
    "free_games_country": {
      "type": "string",
      "label": "Country code for free games",
      "description": "Override country (e.g. PT, GB, DE). Empty = auto-detect from system.",
      "default": ""
    },
    "free_games_auto_check": {
      "type": "boolean",
      "label": "Auto-check free games on startup",
      "default": true
    },
    "free_games_notify": {
      "type": "boolean",
      "label": "Notify when new free games detected",
      "default": true
    },
    "refresh_token": {
      "type": "secret",
      "label": "Refresh Token (auto-managed)",
      "advanced": true
    },
    "account_id": {
      "type": "string",
      "label": "Account ID (auto-managed)",
      "advanced": true
    },
    "display_name": {
      "type": "string",
      "label": "Display Name (auto-managed)",
      "advanced": true
    },
    "_scan_progress": {
      "type": "string",
      "label": "Scan Progress (auto-managed)",
      "advanced": true
    },
    "_last_free_games": {
      "type": "string",
      "label": "Free games cache (auto-managed)",
      "advanced": true
    },
    "_last_free_games_check": {
      "type": "number",
      "label": "Free games last check (auto-managed)",
      "advanced": true
    }
  },
  "slots": [
    {
      "location": "library:scan",
      "label": "Epic Games"
    },
    {
      "location": "matching:scan",
      "label": "Epic Games"
    },
    {
      "location": "activity:panel",
      "label": "Epic Games"
    }
  ],
  "services": ["free-games-provider"],
  "entry": {
    "main": "main.js"
  }
}
