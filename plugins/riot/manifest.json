{
  "name": "Riot Games",
  "version": "0.2.0",
  "description": "Scan your Riot Games library (League of Legends, Valorant, etc.) and match with Otix",
  "author": "Diogo da Silva",
  "repository": "builtin",
  "min_app_version": "0.3.0",
  "permissions": ["worker:filesystem", "storage:local"],
  "slots": [
    { "location": "library:scan", "label": "Riot Games" },
    { "location": "matching:scan", "label": "Riot Games" }
  ],
  "entry": { "main": "main.js" }
}
